<%

def swatch(id)
  %[
    <div class="swatch">
      <div class="swatch-part-wrapper">
        <div class="swatch-part" style="background: var(--color-l-#{id})"><span class="swatch-label">#{id}</span></div>
      </div>
      <div class="swatch-part-wrapper">
        <div class="swatch-part" style="background: var(--color-d-#{id})"><span class="swatch-label">#{id}</span></div>
      </div>
    </div>
  ]
end

%>

