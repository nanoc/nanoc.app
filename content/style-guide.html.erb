<h3>Preformatted text</h3>

<p>Some code:</p>

<pre><code class="language-ruby"><span class="keyword">def</span> <span class="function">say_hi_to</span>(person, params = {})
  puts(<span class="string"><span class="delimiter">"</span><span class="content">What’s up, </span><span class="inline"><span class="inline-delimiter">#{</span>person.first_name<span class="inline-delimiter">}</span></span><span class="content">?</span><span class="delimiter">"</span></span>)
<span class="keyword">rescue</span>
  puts(<span class="string"><span class="delimiter">"</span><span class="content">Uh…&nbsp;hi?</span><span class="delimiter">"</span></span>)
<span class="keyword">end</span></code></pre>
<pre
    class="legacy"
><code class="language-ruby"><span class="comment"># Old approach -- NO LONGER WORKS!</span>
compile <span class="string"><span class="delimiter">'</span><span class="content">*</span><span class="delimiter">'</span></span> <span class="keyword">do</span>
  rep.filter <span class="symbol">:erb</span>
  rep.layout <span class="string"><span class="delimiter">'</span><span class="content">default</span><span class="delimiter">'</span></span>
<span class="keyword">end</span></code></pre>
<pre
    class="new"
><code class="language-ruby"><span class="comment"># New approach</span>
compile <span class="string"><span class="delimiter">'</span><span class="content">*</span><span class="delimiter">'</span></span> <span class="keyword">do</span>
  filter <span class="symbol">:erb</span>
  layout <span class="string"><span class="delimiter">'</span><span class="content">default</span><span class="delimiter">'</span></span>
<span class="keyword">end</span></code></pre>
